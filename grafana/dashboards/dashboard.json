            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "P951FEA4DE68E13C5"
                    },
                    "group": "influxdb",
                    "kind": "DataQuery",
                    "spec": {
                      "query": "from(bucket: \"iot-sensors\")\r\n    |> range(start: ${__from:date:iso}, stop: ${__to:date:iso})\r\n    |> filter(fn: (r) => r._measurement == \"sensor_logs_1\")\r\n    |> filter(fn: (r) => r._field == \"weight\")\r\n    |> aggregateWindow(every: 3s, fn: last, createEmpty: false)\r\n    |> group()\r\n    |> aggregateWindow(every: 3s, fn: sum, createEmpty: false)"
                    },
                    "version": "v0"
