    {
        "id": "df3b252590fe18be",
        "type": "function",
        "z": "dc3901db363fa281",
        "name": "function 2",
        "func": "// Get or create the 100-item array\nlet weights = flow.get(\"deviceWeights\") || new Array(100).fill(0);\n\n// Extract number from \"node-001\"\nlet idMatch = msg.payload.device_id.match(/\\d+/);\nif (idMatch) {\n    let index = parseInt(idMatch[0], 10) - 1;\n    if (index >= 0 && index < 100) {\n        // Store the weight value\n        weights[index] = Number(msg.payload.sensors.weight.value) || 0;\n    }\n}\n\nflow.set(\"deviceWeights\", weights);\nmsg.payload = weights;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1000,
        "y": 420,
        "wires": [
            [
                "42dee0fe9d794335",
                "0669d956c1137b6e"
            ]
        ]
    },
    {
        "id": "0669d956c1137b6e",
        "type": "debug",
        "z": "dc3901db363fa281",
        "name": "debug 2",
        "active": false,
        "tosidebar": true,
        "console": false,
        "tostatus": false,
        "complete": "false",
        "statusVal": "",
        "statusType": "auto",
        "x": 1280,
        "y": 560,
        "wires": []
    },
    {
        "id": "42dee0fe9d794335",
        "type": "ui-template",
        "z": "dc3901db363fa281",
        "group": "bb7bcff9637642b5",
        "page": "",
        "ui": "",
        "name": "",
        "order": 1,
        "width": "0",
        "height": "0",
        "head": "",
        "format": "<template>\n    <div class=\"grid-container\">\n        <div v-for=\"(val, index) in msg.payload\" \n             :key=\"index\"\n             class=\"grid-cell\" \n             :style=\"{ backgroundColor: getCellColor(val) }\">\n            <span class=\"cell-id\">{{ index + 1 }}</span>\n            <span class=\"cell-val\">{{ val }}</span>\n        </div>\n    </div>\n</template>\n\n<script>\nexport default {\n    methods: {\n        getCellColor(val) {\n            if (!val || val <= 0) return '#222';\n            \n            // Normalize 0-4000g to a 0-100 scale for color math\n            const normalized = Math.min(100, val / 40);\n            \n            // Calculate Red and Green components\n            // 0g = Green (0, 255, 0)\n            // 2000g = Yellow (255, 255, 0)\n            // 4000g = Red (255, 0, 0)\n            const r = Math.min(255, (normalized * 5.1));\n            const g = Math.min(255, (510 - (normalized * 5.1)));\n            \n            return `rgb(${Math.floor(r)}, ${Math.floor(g)}, 0)`;\n        }\n    }\n}\n</script>\n\n<style scoped>\n    .grid-container {\n        display: grid;\n        grid-template-columns: repeat(10, 1fr);\n        gap: 2px;\n        width: 100%;\n        background-color: #000;\n        padding: 5px;\n    }\n    .grid-cell {\n        aspect-ratio: 1 / 1;\n        border: 1px solid #333;\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        color: white;\n    }\n    .cell-id { font-size: 0.6rem; opacity: 0.5; }\n    .cell-val { font-size: 0.8rem; font-weight: bold; }\n</style>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 1300,
        "y": 420,
        "wires": [
            []
        ]
    },
