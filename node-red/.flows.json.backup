    {
        "id": "4a445d93551c2f50",
        "type": "ui-template",
        "z": "dc3901db363fa281",
        "group": "c78db07433ae9a79",
        "page": "",
        "ui": "",
        "name": "",
        "order": 1,
        "width": "0",
        "height": "0",
        "head": "",
        "format": "<template>\n    <div class=\"grid-container\">\n        <div v-for=\"(val, index) in msg.payload\" \n             :key=\"index\"\n             class=\"grid-cell\" \n             :style=\"{ backgroundColor: getCellColor(val) }\">\n            <span class=\"cell-id\">{{ index + 1 }}</span>\n            <span class=\"cell-val\">{{ val }}</span>\n        </div>\n    </div>\n</template>\n\n<script>\nexport default {\n    methods: {\n        getCellColor(val) {\n        if (val === undefined || val >= 300) return '#222';\n\n        const normalized = Math.min(100, ((300 - val) / 3.0));\n\n        const r = Math.min(255, (normalized * 5.1));\n        const g = Math.min(255, (510 - (normalized * 5.1)));\n\n        return `rgb(${Math.floor(r)}, ${Math.floor(g)}, 0)`;\n        }\n    }\n}\n</script>\n\n<style scoped>\n    .grid-container {\n        display: grid;\n        grid-template-columns: repeat(10, 1fr);\n        gap: 2px;\n        width: 100%;\n        background-color: #000;\n        padding: 5px;\n    }\n    .grid-cell {\n        aspect-ratio: 1 / 1;\n        border: 1px solid #333;\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        color: white;\n    }\n    .cell-id { font-size: 0.6rem; opacity: 0.5; }\n    .cell-val { font-size: 0.8rem; font-weight: bold; }\n</style>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 1300,
        "y": 360,
        "wires": [
            []
        ]
    },
    {
        "id": "bc9e6c14b5439f30",
        "type": "function",
        "z": "dc3901db363fa281",
        "name": "function 3",
        "func": "// Get or create the 100-item array\nlet distances = flow.get(\"deviceDistances\") || new Array(100).fill(150);\n\n// Extract number from \"node-001\"\nlet idMatch = msg.payload.device_id.match(/\\d+/);\nif (idMatch) {\n    let index = parseInt(idMatch[0], 10) - 1;\n    if (index >= 0 && index < 100) {\n        // Store the weight value\n        distances[index] = Number(msg.payload.sensors.distance.value) || 0;\n    }\n}\n\nflow.set(\"deviceDistances\", distances);\nmsg.payload = distances;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1000,
        "y": 360,
